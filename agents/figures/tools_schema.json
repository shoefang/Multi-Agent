[
    {
        "type": "function",
        "function": {
            "name": "discover_skills",
            "description": "发现当前可用的 Skills。当用户请求可能需要特定能力时调用此工具",
            "parameters": {
                "type": "object",
                "properties": {
                    "skills_dir": {
                        "type": "string",
                        "description": "Skills 目录路径"
                    }
                },
                "required": ["skills_dir"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "load_skill",
            "description": "加载指定 Skill 的完整指令。找到合适的 Skill 后调用此工具获取详细指令",
            "parameters": {
                "type": "object",
                "properties": {
                    "skill_path": {
                        "type": "string",
                        "description": "SKILL.md 文件的路径"
                    }
                },
                "required": ["skill_path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": "读取任意文件内容",
            "parameters": {
                "type": "object",
                "properties": {
                    "file_path": {"type": "string", "description": "文件路径"}
                },
                "required": ["file_path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "write_file",
            "description": "创建或写入文件",
            "parameters": {
                "type": "object",
                "properties": {
                    "file_path": {"type": "string", "description": "文件路径"},
                    "content": {"type": "string", "description": "文件内容"}
                },
                "required": ["file_path", "content"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "list_directory",
            "description": "列出目录内容",
            "parameters": {
                "type": "object",
                "properties": {
                    "dir_path": {"type": "string", "description": "目录路径"}
                },
                "required": ["dir_path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "search",
            "description": "根据检索词从素材库搜索图像",
            "parameters": {
                "type": "object",
                "properties": {
                    "keyword": {"type": "string", "description": "图像检索词"},
                    "para": {"type": "string", "description": "配图插入的段落序号，格式为第n段"},
                    "added": {"type": "string", "description": "已有的配图列表"}
                },
                "required": ["keyword", "para", "added"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "generate_image",
            "description": "使用Gemini生成图像。支持参考图片输入，返回url。",
            "parameters": {
                "type": "object",
                "properties": {
                    "prompt": {
                        "type": "string",
                        "description": "图像生成提示词，详细描述要生成的图像内容、风格和细节"
                    },
                    "save_path": {
                        "type": "string",
                        "description": "生成的图片保存路径（如 /path/to/image.png）"
                    },
                    "image_urls": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "参考图片URL列表（可选），用于基于参考图生成新图"
                    },
                    "aspect_ratio": {
                        "type": "string",
                        "description": "图像宽高比，可选值：1:1（正方形）、16:9（横向）、9:16（纵向）、4:3（宽屏）、3:4（竖屏）",
                        "enum": ["1:1", "16:9", "9:16", "4:3", "3:4"],
                        "default": "1:1"
                    },
                    "return_url": {
                        "type": "boolean",
                        "description": "是否返回生成图片的URL。默认为False（仅保存到本地）。当设置为True时，函数需返回图片URL，用于后续流程使用。",
                        "default": false
                    }
                },
                "required": ["prompt", "save_path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "complete_task",
            "description": "标记任务完成并退出。必须在所有工作完成后调用此工具来正式结束任务。",
            "parameters": {
                "type": "object",
                "properties": {
                    "summary": {
                        "type": "string",
                        "description": "任务完成摘要，描述完成了什么、生成了哪些文件"
                    },
                    "files_created": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "创建的文件路径列表"
                    }
                },
                "required": ["summary"]
            }
        }
    }
]