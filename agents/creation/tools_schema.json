    {
        "type": "function",
        "function": {
            "name": "complete_task",
            "description": "标记任务完成并退出。必须在所有工作完成后调用此工具来正式结束任务。",
            "parameters": {
                "type": "object",
                "properties": {
                    "summary": {
                        "type": "string",
                        "description": "任务完成摘要，描述完成了什么、生成了哪些文件"
                    },
                    "files_created": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "创建的文件路径列表"
                    }
                },
                "required": ["summary"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "generate_image",
            "description": "根据 outline.md 大纲生成四宫格信息图。自动处理 Prompt 生成、合规检测、重试机制和多模态审核。",
            "parameters": {
                "type": "object",
                "properties": {
                    "input_file": {
                        "type": "string",
                        "description": "outline.md 大纲文件路径"
                    },
                    "result_dir": {
                        "type": "string",
                        "description": "结果保存目录路径"
                    }
                },
                "required": ["input_file", "result_dir"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "generate_image_ref",
            "description": "使用Gemini生成图像。支持参考图片输入。",
            "parameters": {
                "type": "object",
                "properties": {
                    "prompt": {
                        "type": "string",
                        "description": "图像生成提示词，详细描述要生成的图像内容、风格和细节"
                    },
                    "save_path": {
                        "type": "string",
                        "description": "生成的图片保存路径（如 /path/to/image.png）"
                    },
                    "image_urls": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "参考图片URL列表（可选），用于基于参考图生成新图"
                    },
                    "aspect_ratio": {
                        "type": "string",
                        "description": "图像宽高比，可选值：1:1（正方形）、16:9（横向）、9:16（纵向）、4:3（宽屏）、3:4（竖屏）",
                        "enum": ["1:1", "16:9", "9:16", "4:3", "3:4"],
                        "default": "1:1"
                    },
                    "return_url": {
                        "type": "boolean",
                        "description": "是否返回生成图片的URL。默认为False（仅保存到本地）。当设置为True时，函数需返回图片URL，用于后续流程使用。",
                        "default": false
                    }
                },
                "required": ["prompt", "save_path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "list_skill_resources",
            "description": "查看特定 Skill 下可用的资源插件（如 styles, layouts 等目录下的文件清单）。",
            "parameters": {
                "type": "object",
                "properties": {
                    "skills_dir": {
                        "type": "string",
                        "description": "Skills 的根目录路径"
                    },
                    "skill_id": {
                        "type": "string",
                        "description": "Skill 的文件夹名称，例如 'miaobi_writer'"
                    }
                },
                "required": ["skills_dir", "skill_id"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "load_config",
            "description": "加载指定的插件配置文件内容（如具体的风格描述或布局模板）。",
            "parameters": {
                "type": "object",
                "properties": {
                    "skills_dir": {
                        "type": "string",
                        "description": "Skills 的根目录路径"
                    },
                    "skill_id": {
                        "type": "string",
                        "description": "Skill 的文件夹名称"
                    },
                    "config_type": {
                        "type": "string",
                        "description": "配置类型，即子目录名，如 'styles' 或 'layouts'"
                    },
                    "config_name": {
                        "type": "string",
                        "description": "配置文件的名称（不带后缀），如 'sincere'"
                    }
                },
                "required": ["skills_dir", "skill_id", "config_type", "config_name"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "image_understanding",
            "description": "使用VLM模型进行图像理解，分析图像内容并生成描述。",
            "parameters": {
                "type": "object",
                "properties": {
                    "image_urls": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "图片URL列表，支持多个图片"
                    },
                    "brief": {
                        "type": "string",
                        "description": "用户上传的简要说明信息（可选）"
                    }
                },
                "required": ["image_urls", "brief"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "upload_image",
            "description": "上传本地图片到BOS云存储，返回图片的预签名URL。",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "本地图片文件路径（如 /path/to/image.png）"
                    }
                },
                "required": ["path"]
            }
        }
    }
